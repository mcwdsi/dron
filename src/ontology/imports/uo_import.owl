AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000189> "count")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000189> "count unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000189> <http://purl.obolibrary.org/obo/UO_0000186>)

# Class: <http://purl.obolibrary.org/obo/UO_0000190> (ratio unit)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Wikipedia:Wikipedia") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/UO_0000190> "A dimensionless unit which denotes an amount or magnitude of one quantity relative to another.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000190> "ratio unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000190> <http://purl.obolibrary.org/obo/UO_0000186>)

# Class: <http://purl.obolibrary.org/obo/UO_0000200> (cell concentration unit)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Bioedonline:Bioedonline") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/UO_0000200> "A concentration unit which denotes the average cell number in a given volume.")
