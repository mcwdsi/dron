AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000105> "frequency unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000105> <http://purl.obolibrary.org/obo/UO_0000000>)

# Class: <http://purl.obolibrary.org/obo/UO_0000176> (milligram per milliliter)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "UOC:GVG") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/UO_0000176> "A mass unit density which is equal to mass of an object in milligrams divided by the volume in milliliters.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000176> "mg/ml")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000176> "milligram per millilitre")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000176> "milligram per milliliter")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000176> <http://purl.obolibrary.org/obo/UO_1000173>)

# Class: <http://purl.obolibrary.org/obo/UO_0000182> (density unit)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Wikipedia:Wikipedia") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/UO_0000182> "A unit which is a standard measure of the influence exerted by some mass.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000182> "density unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000182> <http://purl.obolibrary.org/obo/UO_0000000>)

# Class: <http://purl.obolibrary.org/obo/UO_0000186> (dimensionless unit)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Wikipedia:Wikipedia") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/UO_0000186> "A unit which is a standard measure of physical quantity consisting of only a numerical number without any units.")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000186> "dimensionless unit")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000186> <http://purl.obolibrary.org/obo/UO_0000000>)

# Class: <http://purl.obolibrary.org/obo/UO_0000187> (percent)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Wikipedia:Wikipedia") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/UO_0000187> "A dimensionless ratio unit which denotes numbers as fractions of 100.")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000187> "%")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000187> "percent")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000187> <http://purl.obolibrary.org/obo/UO_0000190>)

