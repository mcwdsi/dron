AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000098> "millilitre")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UO_0000098> "ml")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UO_0000098> "milliliter")
SubClassOf(<http://purl.obolibrary.org/obo/UO_0000098> <http://purl.obolibrary.org/obo/UO_1000099>)

# Class: <http://purl.obolibrary.org/obo/UO_0000105> (frequency unit)

